  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --watch --env-file-if-exists=.env --import tsx src/index.ts",
    "start": "node --env-file-if-exists=.env dist/src/index.js",
